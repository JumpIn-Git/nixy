{
  "telemetry": {
    "diagnostics": true,
    "metrics": false,
  },
  "session": {
    "trust_all_worktrees": true,
  },
  "vim_mode": true,
  "ui_font_size": 16,
  "buffer_font_size": 15,
  "theme": {
    "mode": "dark",
    "light": "One Light",
    "dark": "Noctalia Dark",
  },
  "languages": {
    "Nix": {
      "language_servers": ["nixd", "!nil"],
      "formatter": {
        "external": {
          "command": "alejandra",
          "arguments": ["--quiet", "--"],
        },
      },
    },
  },
}
